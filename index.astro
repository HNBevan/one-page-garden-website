<!-- ═══════════════════════════════════════════════
     STYLES
═══════════════════════════════════════════════ -->
<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: 72px;
  }

  /* ---- Lawn reveal ---- */
  .lawn-reveal {
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.05s linear;
    will-change: clip-path;
  }

  /* ---- Scroll reveal animations ---- */
  .reveal-item {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Hero copy entrance */
  .hero-copy {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s,
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s;
  }

  .hero-copy.is-loaded {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-badge {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.35s,
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.35s;
  }

  .hero-badge.is-loaded {
    opacity: 1;
    transform: translateY(0);
  }

  /* ---- Nav scroll state ---- */
  #site-nav {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 rgba(0,0,0,0.06);
  }

  /* ---- Stagger children ---- */
  .reveal-item:nth-child(2) { transition-delay: 0.07s; }
  .reveal-item:nth-child(3) { transition-delay: 0.14s; }
  .reveal-item:nth-child(4) { transition-delay: 0.21s; }
  .reveal-item:nth-child(5) { transition-delay: 0.28s; }
  .reveal-item:nth-child(6) { transition-delay: 0.35s; }

  /* ---- Reduced motion overrides ---- */
  @media (prefers-reduced-motion: reduce) {
    .reveal-item,
    .hero-copy,
    .hero-badge {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .lawn-reveal {
      clip-path: inset(0 0% 0 0);
      transition: none;
    }

    html {
      scroll-behavior: auto;
    }
  }

  /* ---- Callback toggle active state ---- */
  #callback-toggle.active .toggle-tick {
    opacity: 1;
  }

  #callback-toggle.active #toggle-box {
    background-color: #2d6a4f;
    border-color: #2d6a4f;
  }

  #callback-toggle.active #toggle-tick {
    color: white;
    opacity: 1;
  }
</style>


<!-- ═══════════════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════════════ -->
<script>
  // ── Reduced motion check ────────────────────────
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Hero entrance ───────────────────────────────
  window.addEventListener('DOMContentLoaded', () => {
    if (prefersReducedMotion) return;
    document.querySelector('.hero-copy')?.classList.add('is-loaded');
    document.querySelector('.hero-badge')?.classList.add('is-loaded');
  });

  // ── Nav scroll state ────────────────────────────
  const nav = document.getElementById('site-nav');
  function updateNav() {
    if (window.scrollY > 20) {
      nav.classList.add('nav-scrolled');
    } else {
      nav.classList.remove('nav-scrolled');
    }
  }
  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });

  // ── Mobile menu toggle ──────────────────────────
  const mobToggle = document.getElementById('mob-toggle');
  const mobMenu   = document.getElementById('mob-menu');
  const mobLinks  = document.querySelectorAll('.mob-link');

  mobToggle?.addEventListener('click', () => {
    mobMenu?.classList.toggle('hidden');
  });

  mobLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobMenu?.classList.add('hidden');
    });
  });

  // ── Scroll-reveal: IntersectionObserver ─────────
  if (!prefersReducedMotion) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.reveal-item').forEach(el => {
      observer.observe(el);
    });
  } else {
    // Make all visible immediately under reduced motion
    document.querySelectorAll('.reveal-item').forEach(el => {
      el.classList.add('is-visible');
    });
  }

  // ── Lawn reveal on scroll ───────────────────────
  if (!prefersReducedMotion) {
    const lawnAfter   = document.getElementById('lawn-after');
    const lawnContainer = document.getElementById('lawn-container');
    const labelBefore = document.getElementById('label-before');
    const labelAfter  = document.getElementById('label-after');
    const revealLine  = document.getElementById('reveal-line');

    let revealProgress = 0;
    let ticking = false;

    function computeLawnReveal() {
      if (!lawnContainer || !lawnAfter) return;
      const rect       = lawnContainer.getBoundingClientRect();
      const vh         = window.innerHeight;

      // Begin reveal when container enters viewport, complete at 70% through
      const start    = vh * 0.9;       // when top of container is 90% down
      const end      = vh * 0.2;       // when top is 20% down (well into view)
      const pos      = rect.top;

      const progress = Math.max(0, Math.min(1, (start - pos) / (start - end)));

      if (Math.abs(progress - revealProgress) < 0.002) return;
      revealProgress = progress;

      const pct = Math.round(progress * 100);
      lawnAfter.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;

      // Reveal line follows the clip edge
      if (revealLine) {
        revealLine.style.left   = `${pct}%`;
        revealLine.style.opacity = progress > 0.02 && progress < 0.98 ? '1' : '0';
      }

      // Swap labels
      if (labelBefore && labelAfter) {
        labelBefore.style.opacity = progress > 0.5 ? '0' : '1';
        labelAfter.style.opacity  = progress > 0.1 ? '1' : '0';
      }
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          computeLawnReveal();
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    computeLawnReveal(); // Run once on load
  } else {
    // Show the "after" image fully under reduced motion
    const la = document.getElementById('lawn-after');
    if (la) la.style.clipPath = 'inset(0 0% 0 0)';
    const lb = document.getElementById('label-before');
    const laEl = document.getElementById('label-after');
    if (lb)   lb.style.opacity  = '0';
    if (laEl) laEl.style.opacity = '1';
  }

  // ── Callback toggle ─────────────────────────────
  const callbackToggle = document.getElementById('callback-toggle');
  const callbackCheck  = document.getElementById('callback-check');
  const toggleTick     = document.getElementById('toggle-tick');
  const toggleBox      = document.getElementById('toggle-box');
  const phoneLabel     = document.getElementById('phone-label');

  if (callbackToggle && callbackCheck) {
    callbackToggle.addEventListener('click', () => {
      const isNowChecked = !callbackCheck.checked;
      callbackCheck.checked = isNowChecked;

      // Visual: tick + box fill
      if (toggleTick)  toggleTick.style.opacity  = isNowChecked ? '1' : '0';
      if (toggleBox) {
        toggleBox.style.backgroundColor = isNowChecked ? '#2d6a4f' : '';
        toggleBox.style.borderColor     = isNowChecked ? '#2d6a4f' : '';
        if (toggleTick) toggleTick.style.color = isNowChecked ? 'white' : '';
      }

      // Toggle border on the container
      callbackToggle.style.borderColor  = isNowChecked ? '#52b788' : '';
      callbackToggle.style.backgroundColor = isNowChecked ? 'rgba(216,243,220,0.4)' : '';

      // Update phone label to show it's required for callback
      if (phoneLabel) {
        phoneLabel.textContent = isNowChecked
          ? 'Phone number (required for callback)'
          : 'Phone number';
      }
    });
  }

  // ── Contact form ────────────────────────────────
  const form       = document.getElementById('contact-form');
  const btnLabel   = document.getElementById('btn-label');
  const btnArrow   = document.getElementById('btn-arrow');
  const formSuccess = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const nameVal  = (document.getElementById('name') as HTMLInputElement)?.value.trim();
    const emailVal = (document.getElementById('email') as HTMLInputElement)?.value.trim();

    if (!nameVal || !emailVal) {
      // Simple inline error: highlight empty required fields
      ['name', 'email'].forEach(id => {
        const el = document.getElementById(id) as HTMLInputElement;
        if (el && !el.value.trim()) {
          el.style.borderColor = '#e76f51';
          el.addEventListener('input', () => { el.style.borderColor = ''; }, { once: true });
        }
      });
      return;
    }

    // Simulate submission
    if (btnLabel) btnLabel.textContent = 'Sending...';
    if (btnArrow) btnArrow.style.display = 'none';

    setTimeout(() => {
      form.reset();

      // Reset toggle visual state
      if (toggleTick)  toggleTick.style.opacity  = '0';
      if (toggleBox) {
        toggleBox.style.backgroundColor = '';
        toggleBox.style.borderColor     = '';
      }
      if (callbackToggle) {
        callbackToggle.style.borderColor = '';
        callbackToggle.style.backgroundColor = '';
      }
      if (phoneLabel) phoneLabel.textContent = 'Phone number';

      if (btnLabel) btnLabel.textContent = 'Send Message';
      if (btnArrow) btnArrow.style.display = '';
      if (formSuccess) formSuccess.classList.remove('hidden');

      setTimeout(() => {
        formSuccess?.classList.add('hidden');
      }, 6000);
    }, 1200);
  });

  // ── Smooth anchor scrolling with offset ─────────
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', (e) => {
      const href = anchor.getAttribute('href');
      if (!href || href === '#') return;
      const target = document.querySelector(href);
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth' });
    });
  });
</script>

</body>

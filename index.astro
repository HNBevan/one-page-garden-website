        <form id="contact-form" class="space-y-4" novalidate>

          <!-- Callback toggle - prominent at top -->
          <div id="callback-toggle" class="rounded-xl border-2 border-g-tint bg-g-pale p-4 cursor-pointer hover:border-g-bright transition-colors duration-200" onclick="this.classList.toggle('border-g-bright'); this.classList.toggle('bg-g-tint/50'); document.getElementById('callback-check').checked = !document.getElementById('callback-check').checked; document.getElementById('phone-field').classList.toggle('required-field');">
            <div class="flex items-center gap-3">
              <div id="toggle-box" class="w-5 h-5 rounded border-2 border-g-mid flex items-center justify-center flex-shrink-0 bg-white transition-colors duration-200">
                <svg id="toggle-tick" class="w-3 h-3 text-g-mid opacity-0 transition-opacity duration-200" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <p class="font-heading font-700 text-g-dark text-[15px]">Request a quick callback</p>
                <p class="text-xs text-stone">I'll give you a ring within a few hours during working hours</p>
              </div>
            </div>
            <input type="checkbox" id="callback-check" name="callback" class="sr-only" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="name" class="text-sm font-heading font-600 text-g-ink">Full name <span class="text-cta">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="e.g. Jane Thornton"
                class="px-4 py-3 rounded-lg border border-gray-200 text-[15px] text-g-ink placeholder:text-stone/40 focus:outline-none focus:border-g-mid focus:ring-2 focus:ring-g-mid/20 transition-all duration-200"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="phone" class="text-sm font-heading font-600 text-g-ink" id="phone-label">Phone number</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="07xxx xxx xxx"
                class="px-4 py-3 rounded-lg border border-gray-200 text-[15px] text-g-ink placeholder:text-stone/40 focus:outline-none focus:border-g-mid focus:ring-2 focus:ring-g-mid/20 transition-all duration-200"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-sm font-heading font-600 text-g-ink">Email address <span class="text-cta">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="you@example.com"
              class="px-4 py-3 rounded-lg border border-gray-200 text-[15px] text-g-ink placeholder:text-stone/40 focus:outline-none focus:border-g-mid focus:ring-2 focus:ring-g-mid/20 transition-all duration-200"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="service" class="text-sm font-heading font-600 text-g-ink">Service needed</label>
            <select
              id="service"
              name="service"
              class="px-4 py-3 rounded-lg border border-gray-200 text-[15px] text-g-ink focus:outline-none focus:border-g-mid focus:ring-2 focus:ring-g-mid/20 transition-all duration-200 appearance-none bg-white bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2020%2020%22%3E%3Cpath%20stroke%3D%22%236b7280%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%20stroke-width%3D%221.5%22%20d%3D%22M6%208l4%204%204-4%22%2F%3E%3C%2Fsvg%3E')] bg-no-repeat bg-[right_0.75rem_center] bg-[length:1.25rem]"
            >
              <option value="" disabled selected>Select a service...</option>
              <option value="lawn-mowing">Lawn Mowing</option>
              <option value="hedge-trimming">Hedge Trimming</option>
              <option value="garden-clearance">Garden Clearance</option>
              <option value="border-maintenance">Border Maintenance</option>
              <option value="seasonal-tidy">Seasonal Tidy-up</option>
              <option value="other">Other / Not sure yet</option>
            </select>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="message" class="text-sm font-heading font-600 text-g-ink">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Tell me a bit about your garden or what needs doing. Any details help."
              class="px-4 py-3 rounded-lg border border-gray-200 text-[15px] text-g-ink placeholder:text-stone/40 focus:outline-none focus:border-g-mid focus:ring-2 focus:ring-g-mid/20 transition-all duration-200 resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-g-mid text-white font-heading font-700 text-[15px] py-4 rounded-lg hover:bg-g-dark active:scale-[0.99] transition-all duration-200 flex items-center justify-center gap-2"
          >
            <span id="btn-label">Send Message</span>
            <svg id="btn-arrow" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </button>

          <!-- Success state (hidden by default) -->
          <div id="form-success" class="hidden rounded-lg bg-g-tint border border-g-bright/40 px-4 py-3 text-sm text-g-dark font-heading font-500 text-center">
            Message sent. I'll be in touch shortly.
          </div>

          <p class="text-xs text-stone text-center">
            I typically respond within 2-3 hours on weekdays.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>



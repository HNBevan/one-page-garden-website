---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Professional garden maintenance across Ashford, Kent. Lawn mowing, hedge trimming, garden clearance and border work. Local, reliable, fairly priced." />
  <title>Marty's Garden Maintenance | Ashford, Kent</title>

  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />

  <!-- Lock viewport height before layout so mobile toolbar show/hide can't shift anything -->
  <script is:inline>
    document.documentElement.style.setProperty('--hero-wrap-h', (window.innerHeight * 2.8) + 'px');
  </script>

  <!-- Tailwind CDN: config must be set before the CDN script loads -->
  <script is:inline>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'g-ink':    '#0f1f14',
            'g-dark':   '#1b4332',
            'g-mid':    '#2d6a4f',
            'g-bright': '#52b788',
            'g-tint':   '#d8f3dc',
            'g-pale':   '#f4faf6',
            'cta':      '#e76f51',
            'cta-deep': '#c85e42',
            'stone':    '#6b7280',
          },
          fontFamily: {
            heading: ['Space Grotesk', 'sans-serif'],
            body:    ['DM Sans', 'sans-serif'],
          },
          borderRadius: {
            DEFAULT: '10px',
            'sm':  '6px',
            'lg':  '14px',
            'xl':  '20px',
            'full':'9999px',
          }
        }
      }
    }
  </script>
  <script is:inline src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-white font-body text-g-ink antialiased overflow-x-hidden">

<!-- ═══════════════════════════════════════════════
     NAVIGATION
═══════════════════════════════════════════════ -->
<header id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-5 lg:px-10 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="#" class="flex items-center gap-2.5 flex-shrink-0">
      <span class="w-8 h-8 rounded-full bg-g-mid flex items-center justify-center flex-shrink-0">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M8 2C5 2 3 5 3 8c0 2.5 1.5 4.5 3.5 5.2V11c0-.8.5-1.5 1.5-1.5S9.5 10.2 9.5 11v2.2C11.5 12.5 13 10.5 13 8c0-3-2-6-5-6z" fill="white"/>
          <path d="M8 2v11" stroke="white" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="font-heading text-g-ink text-[18px] leading-none tracking-tight">
        <span style="font-weight:800;">Marty's</span><span style="font-weight:300;"> Garden Maintenance</span><span class="text-g-mid" style="font-weight:800;">.</span>
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden lg:flex items-center gap-14 text-[15px] font-heading text-stone" style="font-weight:700;">
      <li><a href="#services" class="hover:text-g-mid transition-colors">Services</a></li>
      <li><a href="#pricing"  class="hover:text-g-mid transition-colors">Pricing</a></li>
      <li><a href="#gallery"  class="hover:text-g-mid transition-colors">Gallery</a></li>
      <li><a href="#about"    class="hover:text-g-mid transition-colors">About</a></li>
      <li><a href="#reviews"  class="hover:text-g-mid transition-colors">Reviews</a></li>
    </ul>

    <!-- CTA -->
    <a href="#contact" class="hidden lg:inline-flex items-center gap-1.5 bg-black text-white font-heading font-600 text-sm px-5 py-2.5 rounded-full hover:bg-gray-800 active:scale-[0.97] transition-all duration-200">
      Request Callback
    </a>

    <!-- Mobile hamburger -->
    <button id="mob-toggle" class="lg:hidden w-8 h-8 flex flex-col justify-center gap-[5px] group" aria-label="Open menu">
      <span class="h-[2px] bg-g-ink rounded-full transition-all duration-200 group-hover:bg-g-mid"></span>
      <span class="h-[2px] bg-g-ink rounded-full w-3/4 transition-all duration-200 group-hover:bg-g-mid"></span>
      <span class="h-[2px] bg-g-ink rounded-full transition-all duration-200 group-hover:bg-g-mid"></span>
    </button>
  </nav>

  <!-- Mobile drawer -->
  <div id="mob-menu" class="hidden lg:hidden bg-white border-t border-gray-100 shadow-lg">
    <ul class="px-6 py-5 flex flex-col gap-4 text-[15px] font-medium text-stone">
      <li><a href="#services" class="mob-link block hover:text-g-mid transition-colors">Services</a></li>
      <li><a href="#pricing"  class="mob-link block hover:text-g-mid transition-colors">Pricing</a></li>
      <li><a href="#gallery"  class="mob-link block hover:text-g-mid transition-colors">Gallery</a></li>
      <li><a href="#reviews"  class="mob-link block hover:text-g-mid transition-colors">Reviews</a></li>
      <li>
        <a href="#contact" class="mob-link inline-flex bg-black text-white font-heading font-600 text-sm px-5 py-2.5 rounded-full">
          Request Callback
        </a>
      </li>
    </ul>
  </div>
</header>


<!-- ═══════════════════════════════════════════════
     HERO — full-viewport scroll-to-cut reveal
     Wrapper gives 180dvh of scroll travel while
     the section stays pinned at the top.
═══════════════════════════════════════════════ -->
<div id="hero-wrapper" style="height: var(--hero-wrap-h, 280svh); position: relative;">
<section id="hero" class="fixed inset-0 overflow-hidden" style="z-index: 5;">

  <!-- Base layer: overgrown lawn fills the screen -->
  <img
    id="lawn-before"
    src={`${base}/overgrown-lawn.png`}
    alt="Overgrown lawn before garden maintenance"
    class="absolute inset-0 w-full h-full object-cover object-top"
    loading="eager"
  />

  <!-- Reveal layer: freshly cut lawn sweeps in left-to-right -->
  <img
    id="lawn-after"
    src={`${base}/freshly-cut-lawn.png`}
    alt="Freshly cut pristine lawn after garden maintenance"
    class="absolute inset-0 w-full h-full object-cover object-top"
    style="clip-path: inset(0 100% 0 0); will-change: clip-path;"
    loading="eager"
  />

  <!-- Gradient: keeps left-side text readable against both images -->
  <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to right, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.38) 45%, rgba(0,0,0,0.08) 100%);"></div>

  <!-- Mower edge line tracks the reveal boundary -->
  <div
    id="reveal-line"
    class="absolute top-0 bottom-0 pointer-events-none"
    style="left: 0%; width: 2px; background: rgba(255,255,255,0.6); box-shadow: 0 0 10px 2px rgba(255,255,255,0.35); opacity: 0; transition: opacity 0.3s;"
  ></div>

  <!-- Lawnmower: rides the cut boundary at the bottom of the hero -->
  <img
    id="lawnmower"
    src={`${base}/lawnmower.png`}
    alt=""
    aria-hidden="true"
    class="absolute pointer-events-none"
    style="
      bottom: 0;
      left: 0%;
      width: clamp(300px, 28vw, 420px);
      transform: translateX(-100%) translateY(12%);
      z-index: 20;
      filter: drop-shadow(0 4px 12px rgba(0,0,0,0.45));
    "
  />

  <!-- Before / After labels -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-3 pointer-events-none z-10">
    <span id="label-before" class="text-white/70 text-xs font-heading font-600 uppercase tracking-widest" style="transition: opacity 0.5s;">Before</span>
    <span class="w-px h-4 bg-white/30"></span>
    <span id="label-after"  class="text-white   text-xs font-heading font-600 uppercase tracking-widest" style="opacity: 0; transition: opacity 0.5s;">After</span>
  </div>

  <!-- Text overlay -->
  <div class="relative z-10 flex items-center" style="height: 100%;">
    <div class="max-w-7xl mx-auto px-5 lg:px-10 w-full">
      <div class="hero-copy max-w-[820px]">

        <span class="inline-flex items-center gap-1.5 text-white text-xs font-heading font-600 tracking-wide uppercase px-3.5 py-1.5 rounded-full w-fit mb-6 border border-white/25" style="background: rgba(255,255,255,0.12); backdrop-filter: blur(8px);">
          <span class="w-1.5 h-1.5 rounded-full bg-g-bright inline-block"></span>
          Ashford, Kent
        </span>

        <h1 class="font-heading text-white mb-6" style="font-size: clamp(2.6rem, 5.5vw, 5rem); font-weight: 700; line-height: 1.05; letter-spacing: -0.02em;">
          Garden maintenance<br/>
          <span style="color:#fff;">all year round.</span>
        </h1>

        <p class="text-[1.05rem] leading-relaxed max-w-[40ch] mb-8" style="color: rgba(255,255,255,0.72);">
          One local gardener, covering homes across Ashford. Real work, fair prices, tidy finish every time.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="#contact" class="inline-flex items-center gap-2 bg-black text-white font-heading font-700 text-[16px] px-7 py-4 rounded-full hover:bg-gray-800 active:scale-[0.97] transition-all duration-200" style="box-shadow: 0 0 0 3px rgba(255,255,255,0.25), 0 6px 28px rgba(0,0,0,0.45);">
            Request Callback
          </a>
          <a href="#services" class="inline-flex items-center gap-2 bg-white text-g-dark font-heading font-700 text-[16px] px-7 py-4 rounded-full hover:bg-g-pale active:scale-[0.97] transition-all duration-200" style="box-shadow: 0 4px 20px rgba(0,0,0,0.25);">
            See Services
          </a>
        </div>

        <div class="mt-10 flex flex-wrap items-center gap-3">
          <span class="flex items-center gap-2 rounded-full px-4 py-2" style="background:rgba(255,255,255,0.15);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.25);">
            <svg class="w-5 h-5 flex-shrink-0" style="color:#e76f51;" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <span class="font-heading text-white text-[14px]" style="font-weight:700;">5-star rated</span>
          </span>
          <span class="flex items-center gap-2 rounded-full px-4 py-2" style="background:rgba(255,255,255,0.15);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.25);">
            <svg class="w-5 h-5 flex-shrink-0 text-g-bright" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="font-heading text-white text-[14px]" style="font-weight:700;">10+ years experience</span>
          </span>
          <span class="flex items-center gap-2 rounded-full px-4 py-2" style="background:rgba(255,255,255,0.15);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.25);">
            <svg class="w-5 h-5 flex-shrink-0 text-g-bright" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <span class="font-heading text-white text-[14px]" style="font-weight:700;">Fully insured</span>
          </span>
        </div>

      </div>
    </div>
  </div>

</section>
</div>


<!-- ═══════════════════════════════════════════════
     SERVICES
═══════════════════════════════════════════════ -->
<section id="services" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-5 lg:px-10">

    <div class="mb-14 reveal-item">
      <h2 class="font-heading font-800 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-g-ink mb-3">
        What we do
      </h2>
      <p class="text-stone text-[1.05rem] max-w-[48ch]">
        Everything your garden needs, handled with care and a proper job every visit.
      </p>
    </div>

    <!-- Service 1: Lawn Mowing — image left, text right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center mb-16 lg:mb-24 reveal-item">
      <div class="rounded-xl overflow-hidden aspect-[4/3]">
        <img
          src={`${base}/lawn-mowing.jpg`}
          alt="Professional lawn mowing in Ashford"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>
      <div class="lg:pl-6">
        <h3 class="font-heading font-800 text-3xl lg:text-4xl tracking-tight text-g-ink mb-4">
          Lawn Mowing
        </h3>
        <p class="text-stone leading-relaxed mb-5">
          A clean, even cut every time. We mow, collect clippings, and edge borders for a sharp finish. Regular visits keep your lawn healthy through the growing season.
        </p>
        <ul class="space-y-2.5 text-sm text-g-ink">
          <li class="flex items-start gap-2.5">
            <span class="w-4 h-4 rounded-full bg-g-tint flex items-center justify-center mt-0.5 flex-shrink-0">
              <svg class="w-2.5 h-2.5 text-g-mid" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            Clippings collected and removed
          </li>
          <li class="flex items-start gap-2.5">
            <span class="w-4 h-4 rounded-full bg-g-tint flex items-center justify-center mt-0.5 flex-shrink-0">
              <svg class="w-2.5 h-2.5 text-g-mid" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            Border edges trimmed neat
          </li>
          <li class="flex items-start gap-2.5">
            <span class="w-4 h-4 rounded-full bg-g-tint flex items-center justify-center mt-0.5 flex-shrink-0">
              <svg class="w-2.5 h-2.5 text-g-mid" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            Weekly, fortnightly, or monthly visits
          </li>
        </ul>
        <a href="#contact" class="mt-7 inline-flex items-center gap-1.5 text-g-mid font-heading font-600 text-sm hover:gap-3 transition-all duration-200">
          Get a quote
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>

    <!-- Service 2: Hedge Trimming — text left, image right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center mb-16 lg:mb-24 reveal-item">
      <div class="order-2 lg:order-1 lg:pr-6">
        <h3 class="font-heading font-800 text-3xl lg:text-4xl tracking-tight text-g-ink mb-4">
          Hedge Trimming
        </h3>
        <p class="text-stone leading-relaxed mb-5">
          From low box hedges to tall boundary conifers, we cut clean lines and haul everything away. Your neighbours will notice.
        </p>
        <ul class="space-y-2.5 text-sm text-g-ink">
          <li class="flex items-start gap-2.5">
            <span class="w-4 h-4 rounded-full bg-g-tint flex items-center justify-center mt-0.5 flex-shrink-0">
              <svg class="w-2.5 h-2.5 text-g-mid" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            All heights and species
          </li>
          <li class="flex items-start gap-2.5">
            <span class="w-4 h-4 rounded-full bg-g-tint flex items-center justify-center mt-0.5 flex-shrink-0">
              <svg class="w-2.5 h-2.5 text-g-mid" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            Clippings bagged and cleared
          </li>
          <li class="flex items-start gap-2.5">
            <span class="w-4 h-4 rounded-full bg-g-tint flex items-center justify-center mt-0.5 flex-shrink-0">
              <svg class="w-2.5 h-2.5 text-g-mid" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            Shaping and restoration available
          </li>
        </ul>
        <a href="#contact" class="mt-7 inline-flex items-center gap-1.5 text-g-mid font-heading font-600 text-sm hover:gap-3 transition-all duration-200">
          Get a quote
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
      <div class="order-1 lg:order-2 rounded-xl overflow-hidden aspect-[4/3]">
        <img
          src={`${base}/hedge-trimming.jpg`}
          alt="Hedge trimming service in Kent"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Pattern break: full-width banner -->
    <div class="rounded-xl bg-g-dark text-white px-8 py-10 lg:px-14 lg:py-12 mb-16 lg:mb-24 flex flex-col lg:flex-row items-start lg:items-center justify-between gap-6 reveal-item">
      <div>
        <h3 class="font-heading font-800 text-2xl lg:text-3xl tracking-tight mb-2">
          Got an overgrown space that needs a full clear-out?
        </h3>
        <p class="text-g-bright text-[15px] max-w-[52ch]">
          Garden clearances are a speciality. One visit can turn years of growth into a blank canvas.
        </p>
      </div>
      <a href="#contact" class="flex-shrink-0 inline-flex items-center gap-2 bg-black text-white font-heading font-700 text-[15px] px-6 py-3.5 rounded-full hover:bg-gray-800 active:scale-[0.97] transition-all duration-200 whitespace-nowrap">
        Book a Clear-Out
      </a>
    </div>

    <!-- Service 3: Garden Clearance — image left, text right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center mb-16 lg:mb-24 reveal-item">
      <div class="rounded-xl overflow-hidden aspect-[4/3]">
        <img
          src={`${base}/garden-clearance.jpg`}
          alt="Garden clearance service in Ashford"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>
      <div class="lg:pl-6">
        <h3 class="font-heading font-800 text-3xl lg:text-4xl tracking-tight text-g-ink mb-4">
          Garden Clearance
        </h3>
        <p class="text-stone leading-relaxed mb-5">
          Neglected garden? We clear overgrown shrubs, brambles, weeds, and general debris. Everything gets bagged, loaded, and taken away. You start fresh.
        </p>
        <ul class="space-y-2.5 text-sm text-g-ink">
          <li class="flex items-start gap-2.5">
            <span class="w-4 h-4 rounded-full bg-g-tint flex items-center justify-center mt-0.5 flex-shrink-0">
              <svg class="w-2.5 h-2.5 text-g-mid" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            All waste removed from site
          </li>
          <li class="flex items-start gap-2.5">
            <span class="w-4 h-4 rounded-full bg-g-tint flex items-center justify-center mt-0.5 flex-shrink-0">
              <svg class="w-2.5 h-2.5 text-g-mid" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            Brambles, bindweed, and overgrowth
          </li>
          <li class="flex items-start gap-2.5">
            <span class="w-4 h-4 rounded-full bg-g-tint flex items-center justify-center mt-0.5 flex-shrink-0">
              <svg class="w-2.5 h-2.5 text-g-mid" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            Free quotes on request
          </li>
        </ul>
        <a href="#contact" class="mt-7 inline-flex items-center gap-1.5 text-g-mid font-heading font-600 text-sm hover:gap-3 transition-all duration-200">
          Get a quote
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>

    <!-- Service 4: Border Maintenance — text left, image right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center reveal-item">
      <div class="order-2 lg:order-1 lg:pr-6">
        <h3 class="font-heading font-800 text-3xl lg:text-4xl tracking-tight text-g-ink mb-4">
          Border Maintenance
        </h3>
        <p class="text-stone leading-relaxed mb-5">
          Weeded, edged, and tidied borders make a huge difference. We work through your beds carefully, removing weeds by hand and leaving your plants looking their best.
        </p>
        <ul class="space-y-2.5 text-sm text-g-ink">

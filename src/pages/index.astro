</style>


<!-- ═══════════════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════════════ -->
<script is:inline>
  // ── Reduced motion check ────────────────────────
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Lock viewport height so mobile address-bar changes don't cause jumps ──
  const HERO_VH = window.innerHeight;

  // ── Hero entrance (script is at end of body, DOM is ready) ──
  if (!prefersReducedMotion) {
    document.querySelector('.hero-copy')?.classList.add('is-loaded');
    document.querySelector('.hero-badge')?.classList.add('is-loaded');
  }

  // ── Nav scroll state ────────────────────────────
  const nav = document.getElementById('site-nav');
  function updateNav() {
    const hw       = document.getElementById('hero-wrapper');
    const pastHero = hw && window.scrollY > (hw.offsetHeight - (HERO_VH || window.innerHeight));

    if (pastHero) {
      nav.classList.add('nav-hidden');
    } else {
      nav.classList.remove('nav-hidden');
      if (window.scrollY > 20) {
        nav.classList.add('nav-scrolled');
      } else {
        nav.classList.remove('nav-scrolled');
      }
    }
  }
  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });

  // ── Mobile menu toggle ──────────────────────────
  const mobToggle = document.getElementById('mob-toggle');
  const mobMenu   = document.getElementById('mob-menu');
  const mobLinks  = document.querySelectorAll('.mob-link');

  mobToggle?.addEventListener('click', () => {
    mobMenu?.classList.toggle('hidden');
  });

  mobLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobMenu?.classList.add('hidden');
    });
  });

  // ── Scroll-reveal: IntersectionObserver ─────────
  if (!prefersReducedMotion) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.reveal-item').forEach(el => {
      observer.observe(el);
    });
  } else {
    // Make all visible immediately under reduced motion
    document.querySelectorAll('.reveal-item').forEach(el => {
      el.classList.add('is-visible');
    });
  }

  // ── Lawn reveal on scroll ───────────────────────
  // ── Lawn reveal: scroll-driven, wrapper-pinned ──
  const heroWrapper = document.getElementById('hero-wrapper');
  const lawnAfter   = document.getElementById('lawn-after');
  const labelBefore = document.getElementById('label-before');
  const labelAfter  = document.getElementById('label-after');
  const revealLine  = document.getElementById('reveal-line');
  const lawnmower   = document.getElementById('lawnmower');


  if (!prefersReducedMotion && heroWrapper && lawnAfter) {
    let revealTicking = false;
    let lastScrollY   = window.scrollY;
    let facingRight   = true; // tracks current mower direction

    function computeLawnReveal() {
      const wrapperH  = heroWrapper.offsetHeight;
      const viewportH = HERO_VH; // use fixed value — never changes
      const maxScroll = wrapperH - viewportH;
      const progress  = Math.max(0, Math.min(1, window.scrollY / maxScroll));
      const pct       = Math.round(progress * 100);

      // Detect scroll direction and flip mower accordingly
      const scrollingDown = window.scrollY >= lastScrollY;
      lastScrollY = window.scrollY;

      // Reveal the cut lawn left-to-right
      lawnAfter.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;

      // Reveal line sits at the cut boundary
      if (revealLine) {
        revealLine.style.left    = pct + '%';
        revealLine.style.opacity = (progress > 0.01 && progress < 0.99) ? '1' : '0';
      }

      // Lawnmower tracks the boundary; flip when direction changes
      if (lawnmower) {
        lawnmower.style.left    = pct + '%';
        lawnmower.style.opacity = (progress > 0.005 && progress < 0.995) ? '1' : '0';

        if (scrollingDown !== facingRight) {
          facingRight = scrollingDown;
          lawnmower.style.transform = scrollingDown
            ? 'translateX(-100%) translateY(12%)'
            : 'scaleX(-1) translateY(12%)';
        }
      }

      if (labelBefore) labelBefore.style.opacity = progress > 0.55 ? '0' : '1';
      if (labelAfter)  labelAfter.style.opacity  = progress > 0.08 ? '1' : '0';
    }

    window.addEventListener('scroll', () => {
      if (!revealTicking) {
        requestAnimationFrame(() => {
          computeLawnReveal();
          revealTicking = false;
        });
        revealTicking = true;
      }
    }, { passive: true });

    computeLawnReveal(); // set initial state on load

  } else if (prefersReducedMotion && lawnAfter) {
    // Show after state immediately under reduced motion, hide mower
    lawnAfter.style.clipPath = 'inset(0 0% 0 0)';
    if (labelBefore) labelBefore.style.opacity = '0';
    if (labelAfter)  labelAfter.style.opacity  = '1';
    if (lawnmower)   lawnmower.style.display   = 'none';
  }

  // ── Callback toggle ─────────────────────────────
  const callbackToggle = document.getElementById('callback-toggle');
  const callbackCheck  = document.getElementById('callback-check');
  const toggleTick     = document.getElementById('toggle-tick');
  const toggleBox      = document.getElementById('toggle-box');
  const phoneLabel     = document.getElementById('phone-label');

  if (callbackToggle && callbackCheck) {
    callbackToggle.addEventListener('click', () => {
      const cb = /** @type {HTMLInputElement} */ (callbackCheck);
      const isNowChecked = !cb.checked;
      cb.checked = isNowChecked;

      // Visual: tick + box fill
      if (toggleTick)  toggleTick.style.opacity  = isNowChecked ? '1' : '0';
      if (toggleBox) {
        toggleBox.style.backgroundColor = isNowChecked ? '#2d6a4f' : '';
        toggleBox.style.borderColor     = isNowChecked ? '#2d6a4f' : '';
        if (toggleTick) toggleTick.style.color = isNowChecked ? 'white' : '';
      }

      // Toggle border on the container
      callbackToggle.style.borderColor  = isNowChecked ? '#52b788' : '';
      callbackToggle.style.backgroundColor = isNowChecked ? 'rgba(216,243,220,0.4)' : '';

      // Update phone label to show it's required for callback
      if (phoneLabel) {
        phoneLabel.textContent = isNowChecked
          ? 'Phone number (required for callback)'
          : 'Phone number';
      }
    });
  }

  // ── Contact form ────────────────────────────────
  const form       = document.getElementById('contact-form');
  const btnLabel   = document.getElementById('btn-label');
  const btnArrow   = document.getElementById('btn-arrow');
  const formSuccess = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const nameEl  = /** @type {HTMLInputElement} */ (document.getElementById('name'));
    const emailEl = /** @type {HTMLInputElement} */ (document.getElementById('email'));
    const nameVal  = nameEl?.value.trim();
    const emailVal = emailEl?.value.trim();

    if (!nameVal || !emailVal) {
      // Simple inline error: highlight empty required fields
      ['name', 'email'].forEach(id => {
        const el = /** @type {HTMLInputElement} */ (document.getElementById(id));
        if (el && !el.value.trim()) {
          el.style.borderColor = '#e76f51';
          el.addEventListener('input', () => { el.style.borderColor = ''; }, { once: true });
        }
      });
      return;
    }

    // Simulate submission
    if (btnLabel) btnLabel.textContent = 'Sending...';
    if (btnArrow) btnArrow.style.display = 'none';

    setTimeout(() => {
      form.reset();

      // Reset toggle visual state
      if (toggleTick)  toggleTick.style.opacity  = '0';
      if (toggleBox) {
        toggleBox.style.backgroundColor = '';
        toggleBox.style.borderColor     = '';
      }
      if (callbackToggle) {
        callbackToggle.style.borderColor = '';
        callbackToggle.style.backgroundColor = '';
      }
      if (phoneLabel) phoneLabel.textContent = 'Phone number';

      if (btnLabel) btnLabel.textContent = 'Send Message';
      if (btnArrow) btnArrow.style.display = '';
      if (formSuccess) formSuccess.classList.remove('hidden');

      setTimeout(() => {
        formSuccess?.classList.add('hidden');
      }, 6000);
    }, 1200);
  });

  // ── Count-up animation ──────────────────────────
  const countEls = document.querySelectorAll('.count-up');
  if (countEls.length && !prefersReducedMotion) {
    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el     = entry.target;
        const target = parseInt(el.dataset.target, 10);
        const suffix = el.dataset.suffix || '';
        const duration = 1200;
        const start  = performance.now();
        function tick(now) {
          const elapsed  = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased    = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        countObserver.unobserve(el);
      });
    }, { threshold: 0.5 });

    countEls.forEach(el => countObserver.observe(el));
  } else {
    countEls.forEach(el => {
      el.textContent = el.dataset.target + (el.dataset.suffix || '');
    });
  }


  // ── Smooth anchor scrolling with offset ─────────
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', (e) => {
      const href = anchor.getAttribute('href');
      if (!href || href === '#') return;
      const target = document.querySelector(href);
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth' });
    });
  });
</script>

</body>
</html>
